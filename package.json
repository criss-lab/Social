{\n  "name": "bluesky-multirepo",\n  "version": "1.0.0",\n  "description": "A multirepo for atprotocol, Bluesky, and related packages",\n  "private": true,\n  "workspaces": [\n    "packages/*",\n    "apps/*"\n  ],\n  "scripts": {\n    "build": "turbo run build",\n    "dev": "turbo run dev --parallel",\n    "test": "turbo run test",\n    "lint": "turbo run lint",\n    "type-check": "turbo run type-check",\n    "clean": "turbo clean && rm -rf node_modules"\n  },\n  "devDependencies": {\n    "turbo": "^2.0.0"\n  },\n  "packageManager": "pnpm@9.0.0"\n}